# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/creative_impression"

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secure-secret-here-min-32-chars"

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRE="7d"

# ============================================
# API ENDPOINTS
# ============================================
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# PAYMENT GATEWAYS
# ============================================
NEXT_PUBLIC_RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

STRIPE_PUBLIC_KEY="your-stripe-public-key"
STRIPE_SECRET_KEY="your-stripe-secret-key"

PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"

# ============================================
# AWS S3 CONFIGURATION
# ============================================
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_S3_BUCKET_NAME="creative-impression-bucket"

# ============================================
# SHIPPING API
# ============================================
SHIPROCKET_API_KEY="your-shiprocket-api-key"
SHIPROCKET_EMAIL="your-shiprocket-email"
SHIPROCKET_PASSWORD="your-shiprocket-password"

# ============================================
# EMAIL CONFIGURATION
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@creativeimpression.com"

# ============================================
# ANALYTICS & TRACKING
# ============================================
NEXT_PUBLIC_GA_ID="your-google-analytics-id"
NEXT_PUBLIC_FACEBOOK_PIXEL_ID="your-facebook-pixel-id"

# ============================================
# ADMIN CREDENTIALS
# ============================================
ADMIN_EMAIL="admin@creativeimpression.com"
ADMIN_PASSWORD="change-this-password"

# ============================================
# APP SETTINGS
# ============================================
NODE_ENV="development"
NEXT_PUBLIC_SITE_NAME="Creative Impression"
NEXT_PUBLIC_SITE_DESCRIPTION="Premium Fashion & Custom Apparel Platform"

# ============================================
# REDIS CONFIGURATION (Optional)
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# SENDGRID CONFIGURATION (Optional)
# ============================================
SENDGRID_API_KEY="your-sendgrid-api-key"
SENDGRID_FROM_EMAIL="noreply@creativeimpression.com"
